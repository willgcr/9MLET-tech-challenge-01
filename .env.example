# Copy this file to .env and fill in the values. .env is gitignored.
# Loaded automatically by churn.config via python-dotenv.

# --- Kaggle API (required for the dataset download) ---
# Get the credentials at https://www.kaggle.com/settings -> API -> Create New Token.
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Optional overrides ---
# RANDOM_SEED=42
# MLFLOW_TRACKING_URI=file:///abs/path/to/mlruns
# MLFLOW_EXPERIMENT_NAME=telco-churn
# LOG_FORMAT=json   # set to "text" for human-readable local logs
